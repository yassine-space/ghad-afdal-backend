CREATE TABLE IF NOT EXISTS "users" (
    "id" serial NOT NULL PRIMARY KEY,
    "password" varchar(128) NOT NULL,
    "last_login" timestamptz NULL,
    "is_superuser" boolean NOT NULL,
    "username" varchar(150) NOT NULL UNIQUE,
    "first_name" varchar(150) NOT NULL,
    "last_name" varchar(150) NOT NULL,
    "email" varchar(254) NOT NULL,
    "is_staff" boolean NOT NULL,
    "is_active" boolean NOT NULL,
    "date_joined" timestamptz NOT NULL
);

CREATE TABLE IF NOT EXISTS "user_profiles" (
    "id" serial NOT NULL PRIMARY KEY,
    "user_id" integer NOT NULL UNIQUE REFERENCES "users"("id") DEFERRABLE INITIALLY DEFERRED,
    "person_id" integer NULL UNIQUE REFERENCES "persons"("id") DEFERRABLE INITIALLY DEFERRED
);

CREATE TABLE IF NOT EXISTS "user_activity_access" (
    "id" serial NOT NULL PRIMARY KEY,
    "access_level" varchar(10) NOT NULL,
    "granted_at" timestamptz NOT NULL,
    "user_id" integer NOT NULL REFERENCES "users"("id") DEFERRABLE INITIALLY DEFERRED,
    "activity_id" integer NOT NULL REFERENCES "ghadapi_activity"("id") DEFERRABLE INITIALLY DEFERRED,
    UNIQUE ("user_id", "activity_id")
);
